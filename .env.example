# ============================================================================
# ROHU Solutions Marketing Web — environment variables
# Copy this file to .env.local and fill in the values for local development.
# On Heroku, set these as Config Vars (Settings → Reveal Config Vars).
# NEVER commit .env.local — it is gitignored.
# ============================================================================

# --- Public site ------------------------------------------------------------
# Canonical public URL of the marketing site (used for sitemap, OG, metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ROHU Contable demo (public by design, fake data) ---------------------
# URL of the hosted demo instance of ROHU Contable
NEXT_PUBLIC_DEMO_URL=https://rohu-accountant-42a1913f511f.herokuapp.com/
# Demo credentials visible on the product page (PUBLIC, demo-only, fake data)
NEXT_PUBLIC_DEMO_USER=demo@rohu-contable.com
NEXT_PUBLIC_DEMO_PASSWORD=demo1234

# --- WhatsApp (visitor-facing live-chat channel) ---------------------------
# Owner phone number in E.164 format WITHOUT the leading "+"
# Example for Colombia: 573001234567 (country code 57 + 10-digit number)
NEXT_PUBLIC_WHATSAPP_PHONE=573001234567
# Fallback pre-filled message. The WhatsAppFab and Footer actually use
# buildContextualWhatsAppMessage() which picks a message based on the
# current pathname, so this env var is a safety net only.
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hola, me interesa ROHU Solutions y quisiera más información, ¿en qué pueden ayudarme?

# --- Telegram (optional visitor-facing alternative channel) ----------------
# Username without the "@". Leave empty to hide Telegram UI entirely.
NEXT_PUBLIC_TELEGRAM_USERNAME=

# --- Telegram Bot (server-only, push notifications to the owner) ----------
# When a new lead is submitted, the site POSTs a formatted message to this bot
# so the owner gets an instant notification on their phone.
#
# Setup:
#   1. Open Telegram → search @BotFather → send /newbot → copy the TOKEN.
#   2. Open your new bot → send /start (so the bot is allowed to message you).
#   3. Open https://api.telegram.org/bot<TOKEN>/getUpdates and copy your chat.id.
#   4. Paste both values below. Keep them SECRET — do not commit this file.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SMTP (email notifications) -------------------------------------------
# Every new lead is emailed to SMTP_TO using these credentials.
# Gmail example: requires 2FA + App Password (https://myaccount.google.com/apppasswords)
#   1. Enable 2FA on your Google Account.
#   2. Generate an App Password labeled "ROHU Marketing Web".
#   3. Paste the 16-character token (with or without spaces) as SMTP_PASS.
#   4. If empty, email sending is silently skipped (the form still works).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hgomezgonzalez@gmail.com
SMTP_PASS=
SMTP_FROM="ROHU Solutions <hgomezgonzalez@gmail.com>"
SMTP_TO=hgomezgonzalez@gmail.com

# --- Optional external CRM webhook -----------------------------------------
# If set, every new lead will ALSO be POSTed to this URL (fire-and-forget).
# Leave empty to skip. Useful for HubSpot/Pipedrive/Zapier/Make integrations.
LEAD_API_URL=
