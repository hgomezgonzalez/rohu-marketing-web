# ============================================================================
# ROHU Marketing Web — environment variables
# Copy this file to .env.local and fill in the values for local development.
# On Heroku, set these as Config Vars (Settings → Reveal Config Vars).
# ============================================================================

# --- Public site ------------------------------------------------------------
# Canonical public URL of the marketing site (used for sitemap, OG, metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ROHU Contable demo (public by design) ---------------------------------
# URL of the hosted demo instance of ROHU Contable
NEXT_PUBLIC_DEMO_URL=https://rohu-contable-prod-3fba93dd2eb4.herokuapp.com/
# Demo credentials visible on the landing page (PUBLIC, demo-only, fake data)
NEXT_PUBLIC_DEMO_USER=rohu-contable
NEXT_PUBLIC_DEMO_PASSWORD=rohu-contable

# --- WhatsApp (visitor-facing live-chat channel) ---------------------------
# Owner phone number in E.164 format WITHOUT the leading "+"
# Example for Colombia: 57300XXXXXXX
NEXT_PUBLIC_WHATSAPP_PHONE=57300XXXXXXX
# Pre-filled message when the user taps the WhatsApp button
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hola, me interesa ROHU Contable y quiero más información.

# --- Telegram (optional visitor-facing alternative channel) ----------------
# Username without the "@". Leave empty to hide Telegram UI entirely.
NEXT_PUBLIC_TELEGRAM_USERNAME=

# --- Telegram Bot (server-only, push notifications to the owner) ----------
# When a new lead is submitted, the site POSTs a formatted message to this bot
# so the owner gets an instant notification on their phone.
#
# Setup:
#   1. Open Telegram → search @BotFather → send /newbot → copy the TOKEN.
#   2. Open your new bot → send /start (so the bot is allowed to message you).
#   3. Open https://api.telegram.org/bot<TOKEN>/getUpdates and copy your chat.id.
#   4. Paste both values below. Keep them SECRET — do not commit this file.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional external CRM webhook -----------------------------------------
# If set, every new lead will ALSO be POSTed to this URL (fire-and-forget).
# Leave empty to skip. Useful for HubSpot/Pipedrive/Zapier/Make integrations.
LEAD_API_URL=
